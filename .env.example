# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Paystack Payment Configuration
# Get these from your Paystack Dashboard (Settings > API Keys & Webhooks)
PAYSTACK_SECRET_KEY=
VITE_PAYSTACK_PUBLIC_KEY=

# Firebase Admin Configuration
# FIREBASE_SERVICE_ACCOUNT_JSON: The full JSON string of your Firebase Service Account private key.
FIREBASE_SERVICE_ACCOUNT_JSON=
# ADMIN_CLAIM_SECRET: A secret string used to protect the /api/set-admin endpoint.
ADMIN_CLAIM_SECRET=

# External Socratic Tutor AI API
VITE_TUTOR_API_KEY=
