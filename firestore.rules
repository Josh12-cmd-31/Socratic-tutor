rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isVerified() {
      // For standard writes, mandate verification if possible, but keep simple for now
      return request.auth.token.email_verified == true;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // --- Validation Helpers ---
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('isPremium' in data) || data.isPremium is bool);
    }

    // --- Collections ---
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) &&
                       incoming().keys().hasAll(['uid', 'email', 'createdAt']) &&
                       incoming().uid == request.auth.uid &&
                       incoming().createdAt == request.time &&
                       isValidUser(incoming());
      allow update: if isOwner(userId) && isValidId(userId) &&
                       incoming().uid == existing().uid &&
                       incoming().createdAt == existing().createdAt &&
                       isValidUser(incoming()) && (
                         // Action: Only allow display name change from client
                         incoming().diff(existing()).affectedKeys().hasOnly(['displayName'])
                       );
    }

    match /payments/{paymentId} {
      allow create: if isAuthenticated() 
                    && incoming().amount is int 
                    && incoming().amount > 0
                    && incoming().userId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
