rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isAuthenticated() {
      return isSignedIn();
    }

    // --- Validation Helpers ---
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('isPremium' in data) || data.isPremium is bool) &&
             (!('voiceGender' in data) || (data.voiceGender in ['male', 'female'])) &&
             (!('speechRate' in data) || (data.speechRate is number && data.speechRate >= 0.1 && data.speechRate <= 5.0)) &&
             (!('speechPitch' in data) || (data.speechPitch is number && data.speechPitch >= 0.1 && data.speechPitch <= 2.0));
    }

    function isNotBanned(userId) {
      let userDoc = /databases/$(database)/documents/users/$(userId);
      return !exists(userDoc) || get(userDoc).data.get('isBanned', false) == false;
    }

    // --- Collections ---
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) &&
                       incoming().uid == request.auth.uid &&
                       incoming().createdAt == request.time &&
                       isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) &&
                       // Check that the user is NOT attempting to unban themselves if they were banned
                       (!('isBanned' in existing()) || existing().isBanned == false) &&
                       incoming().uid == existing().uid &&
                       incoming().createdAt == existing().createdAt &&
                       isValidUser(incoming()) && (
                         isAdmin() ||
                         // Action: Only allow display name change from client
                         incoming().diff(existing()).affectedKeys().hasOnly(['displayName'])
                       );
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow create: if isSignedIn() 
                    && isNotBanned(request.auth.uid)
                    && incoming().amount is int 
                    && incoming().amount > 0
                    && incoming().userId == request.auth.uid;
      allow read: if (isSignedIn() && isNotBanned(request.auth.uid) && resource.data.userId == request.auth.uid) || isAdmin();
      allow list: if isAdmin();
    }

    match /conversations/{conversationId} {
      function isValidConversation(data) {
        return data.userId == request.auth.uid &&
               data.messages is list &&
               (!('title' in data) || (data.title is string && data.title.size() <= 200));
      }

      allow create: if isSignedIn() && isNotBanned(request.auth.uid) && 
                       incoming().userId == request.auth.uid &&
                       incoming().createdAt == request.time &&
                       isValidConversation(incoming());
      
      allow get: if isSignedIn() && isNotBanned(request.auth.uid) && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow list: if isSignedIn() && isNotBanned(request.auth.uid) && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow update: if isSignedIn() && isNotBanned(request.auth.uid) && 
                       (resource.data.userId == request.auth.uid || isAdmin()) &&
                       isValidConversation(incoming()) &&
                       incoming().userId == existing().userId &&
                       incoming().createdAt == existing().createdAt &&
                       incoming().updatedAt == request.time &&
                       incoming().diff(existing()).affectedKeys().hasAny(['messages', 'title', 'updatedAt']);
      
      allow delete: if isSignedIn() && isNotBanned(request.auth.uid) && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
