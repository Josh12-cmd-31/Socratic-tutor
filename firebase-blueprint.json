{
  "entities": {
    "User": {
      "title": "User",
      "description": "Information about a registered student",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Unique identifier from Firebase Auth"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User email address"
        },
        "displayName": {
          "type": "string",
          "description": "User's full name"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Metadata for when account was created"
        },
        "isPremium": {
          "type": "boolean",
          "description": "Whether the user has paid for lifetime access"
        },
        "deviceId": {
          "type": "string",
          "description": "Unique identifier for the device used"
        },
        "isBanned": {
          "type": "boolean",
          "description": "Whether the user is banned due to policy violation"
        },
        "banReason": {
          "type": "string",
          "description": "Reason for the account ban"
        }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A saved chat session between student and Socratic Tutor",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The student who owns this conversation"
        },
        "title": {
          "type": "string",
          "description": "User-defined or auto-generated title for the session"
        },
        "messages": {
          "type": "array",
          "description": "Serialized chat history"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the chat was saved"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last time this chat was modified"
        }
      },
      "required": ["userId", "messages", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of student profiles"
    },
    "conversations/{conversationId}": {
      "schema": "Conversation",
      "description": "Storage for saved tutoring sessions"
    },
    "payments/{paymentId}": {
      "schema": {
        "type": "object",
        "properties": {
          "userId": { "type": "string" },
          "amount": { "type": "integer" },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["userId", "amount", "createdAt"]
      },
      "description": "Log of student payments and contributions"
    }
  }
}
